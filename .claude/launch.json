{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Laravel Backend",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "serve", "--host=0.0.0.0", "--port=8000"],
      "cwd": "backend",
      "port": 8000
    },
    {
      "name": "Vue.js Frontend (Vite)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "npm", "run", "dev"],
      "cwd": "frontend",
      "port": 5173
    },
    {
      "name": "Full Stack (Backend + Frontend)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "npm", "run", "dev"],
      "port": 5173
    },
    {
      "name": "Laravel Queue Worker",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && php artisan queue:work redis --sleep=3 --tries=3"],
      "port": 0
    }
  ]
}
